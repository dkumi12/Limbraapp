# Supabase Credentials (Required for Auth & Database)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Default AI Provider Configuration (stretchgpt, bedrock, or openrouter)
VITE_AI_PROVIDER=stretchgpt

# HuggingFace API Token (Required if VITE_AI_PROVIDER=stretchgpt)
VITE_HF_WRITE_TOKEN=your_huggingface_token_here
HF_WRITE_TOKEN=your_huggingface_token_here # Also needed for Vercel Serverless Function

# AWS Bedrock Credentials (Required if VITE_AI_PROVIDER=bedrock)
VITE_AWS_ACCESS_KEY=your_aws_access_key
VITE_AWS_SECRET_KEY=your_aws_secret_key
VITE_AWS_REGION=us-east-1
VITE_AWS_MODEL_ID=mistral.mistral-small-2402-v1:0

# OpenRouter API Key (Required if VITE_AI_PROVIDER=openrouter)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here
VITE_SELECTED_MODEL=anthropic/claude-3-haiku

# YouTube Data API Key (Required for video loading)
VITE_YOUTUBE_API_KEY=your_youtube_key_here
